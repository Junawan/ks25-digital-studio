import { useCallback, useMemo, useState } from "react";

import { FirestorePosSettingsRepository } from "../repositories/FirestorePosSettingsRepository";
import { DEFAULT_POS_SETTINGS, PosSettings } from "../types/PosSettings";
import { GetPosSettingsUseCase } from "../usecases/GetPosSettingsUseCase";
import { SavePosSettingsUseCase } from "../usecases/SavePosSettingsUseCase";

export function usePosSettings() {
  const repository = useMemo(
    () => new FirestorePosSettingsRepository(),
    []
  );

  const getUseCase = useMemo(
    () => new GetPosSettingsUseCase(repository),
    [repository]
  );

  const saveUseCase = useMemo(
    () => new SavePosSettingsUseCase(repository),
    [repository]
  );

  const [settings, setSettings] =
    useState<
      Omit<
        PosSettings,
        "companyId" | "createdAt" | "updatedAt"
      >
    >(DEFAULT_POS_SETTINGS);

  const [loading, setLoading] =
    useState(false);

  const loadSettings = useCallback(
    async (companyId: string) => {
      setLoading(true);

      try {
        const result =
          await getUseCase.execute(companyId);

        if (result) {
          setSettings({
            address: result.address,
            phone: result.phone,
            email: result.email,
            website: result.website,
            logoUrl: result.logoUrl,
            bankName: result.bankName,
            accountNumber: result.accountNumber,
            accountHolder: result.accountHolder,
            qrisImageUrl: result.qrisImageUrl,
            receiptFooter: result.receiptFooter,
            paperSize: result.paperSize,
            autoPrint: result.autoPrint,
          });
        }
      } finally {
        setLoading(false);
      }
    },
    [getUseCase]
  );

  const saveSettings = useCallback(
    async (
      companyId: string
    ) => {
      await saveUseCase.execute({
        companyId,
        ...settings,
        createdAt: new Date(),
        updatedAt: new Date(),
      });
    },
    [saveUseCase, settings]
  );

  return {
    settings,
    setSettings,

    loading,

    loadSettings,
    saveSettings,
  };
}